# Chat Service Environment Variables
CHAT_SERVICE_PORT=3003

# MongoDB (Chat DB)
CHAT_DB_URI=mongodb://localhost:27017/chat_db

# JWT (for Socket.io auth)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Encryption (AES-256-GCM for messages)
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# gRPC Service URLs
USER_GRPC_URL=localhost:50052

# Logging
LOG_LEVEL=debug
NODE_ENV=development
