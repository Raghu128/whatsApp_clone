# Presence Service Environment Variables
PRESENCE_SERVICE_PORT=3004

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Redis (PRIMARY data store — no persistent DB)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Encryption
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# Logging
LOG_LEVEL=debug
NODE_ENV=development
