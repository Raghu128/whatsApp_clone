# ============================================
# WhatsApp Clone — Environment Variables
# ============================================
# Copy this file to .env and fill in values:
#   cp .env.example .env

# ── Node Environment ──
NODE_ENV=development

# ── JWT Configuration ──
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── PostgreSQL (Auth DB) ──
AUTH_DB_HOST=localhost
AUTH_DB_PORT=5432
AUTH_DB_NAME=auth_db
AUTH_DB_USER=postgres
AUTH_DB_PASSWORD=postgres_password

# ── PostgreSQL (User DB) ──
USER_DB_HOST=localhost
USER_DB_PORT=5433
USER_DB_NAME=user_db
USER_DB_USER=postgres
USER_DB_PASSWORD=postgres_password

# ── MongoDB (Chat DB) ──
CHAT_DB_URI=mongodb://localhost:27017/chat_db

# ── MongoDB (Notification DB) ──
NOTIFICATION_DB_URI=mongodb://localhost:27017/notification_db

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Encryption (AES-256-GCM) ──
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# ── Service Ports ──
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
CHAT_SERVICE_PORT=3003
PRESENCE_SERVICE_PORT=3004
MEDIA_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006

# ── gRPC Ports ──
AUTH_GRPC_PORT=50051
USER_GRPC_PORT=50052

# ── Service URLs (Docker) ──
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
CHAT_SERVICE_URL=http://localhost:3003
PRESENCE_SERVICE_URL=http://localhost:3004
MEDIA_SERVICE_URL=http://localhost:3005
NOTIFICATION_SERVICE_URL=http://localhost:3006

# ── Logging ──
LOG_LEVEL=debug
